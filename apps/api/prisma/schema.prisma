datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  BRANCH_MANAGER
  AGENT
  VIEWER
}

enum LeadStatus {
  NEW_LEAD
  CONTACTED
  COUNSELLING
  DEMO_CLASS
  DEMO_SESSION
  ENROLLED
  TRAINING
  EXAM_BOOKED
  COURSE_ONGOING
  COMPLETED
  DOCUMENTS_PENDING
  DOCUMENTS_RECEIVED
  UNIVERSITY_APPLIED
  OFFER_LETTER
  VISA_PROCESS
  ADMISSION_CLOSED
  LOST
}

enum LeadCategory {
  STUDY_ABROAD
  IELTS
  PTE
  ENGLISH_SPEAKING
  COMPUTER_COURSE
  DIGITAL_MARKETING
  OTHER
}


enum LeadSource {
  WEBSITE_SDK
  WHATSAPP
  TELEPHONY
  MANUAL
  API_IMPORT
  FACEBOOK_ADS
  DYNAMIC_FORM
}

enum DocumentType {
  PASSPORT
  IELTS
  MARKSHEET_10TH
  MARKSHEET_12TH
  DEGREE
  SOP
  LOR
  OFFER_LETTER
  VISA_DOCUMENT
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FollowupStatus {
  SCHEDULED
  COMPLETED
  MISSED
  CANCELLED
}

enum ApplicationStatus {
  SHORTLISTED
  APPLICATION_STARTED
  APPLICATION_SUBMITTED
  UNDER_REVIEW
  DECISION_RECEIVED
}

enum OfferStatus {
  NONE
  CONDITIONAL_OFFER
  UNCONDITIONAL_OFFER
  OFFER_ACCEPTED
  OFFER_REJECTED
}

enum VisaStatus {
  NOT_STARTED
  VISA_APPLIED
  VISA_BIOMETRICS
  VISA_APPROVED
  VISA_REJECTED
}

model Tenant {
  id           String     @id @default(uuid())
  name         String
  domain       String     @unique
  customDomain String?    @unique
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  users        User[]
  branches     Branch[]
  auditLogs    AuditLog[]
  leads        Lead[]
  visitors     Visitor[]
  emailSetting EmailSetting?
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  code      String   @unique
  city      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  leads     Lead[]

  @@index([tenantId])
}

model User {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role       @default(AGENT)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  auditLogs    AuditLog[]
  assignedLeads Lead[]    @relation("LeadAssignee")
  notes        Note[]
  activities   Activity[]
  followups    Followup[]
  approvedDocs LeadDocument[] @relation("DocApprover")
  notifications Notification[]
  sessions     UserSession[]
}

model Lead {
  id             String      @id @default(uuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId       String?
  branch         Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  firstName      String?
  lastName       String?
  email          String?
  normalizedEmail String?
  phone          String?
  normalizedPhone String?
  status         LeadStatus  @default(NEW_LEAD)
  source         LeadSource  @default(MANUAL)
  assigneeId     String?
  assignee       User?       @relation("LeadAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  visitorId      String?
  visitor        Visitor?    @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  submissionCount Int            @default(1)
  leadCategory   LeadCategory @default(STUDY_ABROAD)
  preferredCountry String?
  preferredCourse  String?
  planningTimeline String?
  intendedIntake   String?
  englishLevel     String?
  targetScore      String?
  purpose          String?
  courseInterest   String?
  readinessScore Float?

  submissions    LeadSubmission[]
  studentProfile StudentProfile?
  documents      LeadDocument[]
  followups      Followup[]
  activities     Activity[]
  notes          Note[]
  applications   Application[]
  communicationQueues CommunicationQueue[]
  communicationLogs   CommunicationLog[]
  brochureAssignments BrochureAssignment[]
  engagementScore     Int                 @default(0)
  engagementLabel     String              @default("Cold")


  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@index([normalizedEmail])
  @@index([normalizedPhone])
}

model StudentProfile {
  id                   String   @id @default(uuid())
  leadId               String   @unique
  lead                 Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  targetCountry        String?
  targetCourse         String?
  intake               String?
  ieltsStatus          String?
  passportStatus       String?
  educationLevel       String?
  percentageGpa        String?
  budget               String?
  currentQualification String?
  updatedAt            DateTime @updatedAt
}

model Note {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

enum DocumentStatus {
  PENDING
  UPLOADED
  VERIFIED
  REJECTED
}

model LeadDocument {
  id               String         @id @default(uuid())
  leadId           String
  lead             Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  documentType     String
  version          Int            @default(1)
  isCurrent        Boolean        @default(true)
  isRequired       Boolean        @default(true)
  status           DocumentStatus @default(PENDING)
  originalFileName String?
  storedFileName   String?
  filePath         String?
  fileSize         Int?
  mimeType         String?
  uploadedAt       DateTime?
  verifiedAt       DateTime?
  rejectedAt       DateTime?
  verificationNote String?
  expiryDate       DateTime?
  approvedById     String?
  approvedBy       User?          @relation("DocApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([leadId])
  @@index([status])
}

model Followup {
  id             String         @id @default(uuid())
  leadId         String
  lead             Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedUserId String
  assignedUser   User           @relation(fields: [assignedUserId], references: [id], onDelete: Cascade)
  followupDate   DateTime
  status         FollowupStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([leadId])
  @@index([assignedUserId])
  @@index([followupDate])
  @@index([status])
}

model Activity {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  type        String
  description String
  meta        Json?
  createdAt   DateTime @default(now())

  @@index([leadId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String
  targetEntity String
  targetId     String
  beforeState  Json?
  afterState   Json?
  ipAddress    String?
  timestamp    DateTime @default(now())

  @@index([tenantId])
  @@index([targetEntity, targetId])
  @@index([timestamp])
}

model Visitor {
  id        String           @id @default(uuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  leads     Lead[]
  sessions  VisitorSession[]

  @@index([tenantId])
}

model VisitorSession {
  id          String         @id @default(uuid())
  visitorId   String
  visitor     Visitor        @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  sessionId   String         @unique
  referrer    String?
  landingPage String?
  deviceType  String?
  browser     String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  createdAt   DateTime       @default(now())
  events      VisitorEvent[]
  sources     TrackingSource[]

  @@index([visitorId])
  @@index([sessionId])
}

model VisitorEvent {
  id        String         @id @default(uuid())
  sessionId String
  session   VisitorSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  type      String
  meta      Json?
  createdAt DateTime       @default(now())

  @@index([sessionId])
}

model TrackingSource {
  id          String         @id @default(uuid())
  sessionId   String
  session     VisitorSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  source      String
  landingPage String
  referrer    String?
  createdAt   DateTime       @default(now())

  @@index([sessionId])
}

model LeadSubmission {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  country     String?
  course      String?
  intake      String?
  source      String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  referrer    String?
  landingPage String?
  createdAt   DateTime @default(now())

  preferredCountry String?
  preferredCourse  String?
  intendedIntake   String?
  planningTimeline String?
  englishLevel     String?
  targetScore      String?
  purpose          String?
  courseInterest   String?

  @@index([leadId])
}

model Application {
  id                String            @id @default(uuid())
  leadId            String
  lead              Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  universityName    String
  country           String
  courseName        String
  intake            String
  applicationStatus ApplicationStatus @default(SHORTLISTED)
  offerStatus       OfferStatus       @default(NONE)
  visaStatus        VisaStatus        @default(NOT_STARTED)
  applicationDate   DateTime?
  offerDate         DateTime?
  visaDate          DateTime?
  tuitionFee        Float?
  scholarshipAmount Float?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([leadId])
}

enum CommunicationChannel {
  EMAIL
  WHATSAPP
}

enum QueueStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model CommunicationQueue {
  id          String   @id @default(cuid())
  leadId      String
  channel     CommunicationChannel
  eventType   String
  payload     Json
  status      QueueStatus @default(PENDING)
  createdAt   DateTime @default(now())
  processedAt DateTime?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model CommunicationTemplate {
  id          String   @id @default(cuid())
  name        String
  channel     CommunicationChannel
  subject     String?
  content     String
  htmlContent String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommunicationLog {
  id         String   @id @default(cuid())
  leadId     String
  channel    CommunicationChannel
  eventType  String
  status     QueueStatus
  recipient  String
  message    String
  sentAt     DateTime @default(now())
  openedAt   DateTime?
  clickedAt  DateTime?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model EmailSetting {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  host        String
  port        Int
  username    String
  password    String
  senderName  String
  senderEmail String
  encryption  String   @default("TLS")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Brochure {
  id          String               @id @default(uuid())
  title       String
  category    LeadCategory
  filePath    String
  totalPages  Int
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  assignments BrochureAssignment[]
}

model BrochureAssignment {
  id         String            @id @default(uuid())
  leadId     String
  lead       Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  brochureId String
  brochure   Brochure          @relation(fields: [brochureId], references: [id], onDelete: Cascade)
  token      String            @unique
  assignedAt DateTime          @default(now())
  assignedBy String?
  tracking   BrochureTracking?
}

model BrochureTracking {
  id                   String             @id @default(uuid())
  brochureAssignmentId String             @unique
  assignment           BrochureAssignment @relation(fields: [brochureAssignmentId], references: [id], onDelete: Cascade)
  opened               Boolean            @default(false)
  readingTime          Int                @default(0) // in seconds
  pageViews            Int                @default(0)
  completionPercentage Float              @default(0.0) // 0 to 100
  lastPageViewed       Int                @default(0)
  downloadCount        Int                @default(0)
  viewedPages          String             @default("") // comma-separated unique page numbers (e.g. "1,2")
  engagementScore      Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

