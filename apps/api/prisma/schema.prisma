datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SUPER_ADMIN
  COUNSELLOR
}

enum LeadStatus {
  NEW_LEAD
  CONTACTED
  COUNSELLING
  DEMO_CLASS
  DEMO_SESSION
  ENROLLED
  TRAINING
  EXAM_BOOKED
  COURSE_ONGOING
  COMPLETED
  DOCUMENTS_PENDING
  DOCUMENTS_RECEIVED
  UNIVERSITY_APPLIED
  OFFER_LETTER
  VISA_PROCESS
  ADMISSION_CLOSED
  LOST
}

enum LeadCategory {
  STUDY_ABROAD
  IELTS
  PTE
  ENGLISH_SPEAKING
  COMPUTER_COURSE
  DIGITAL_MARKETING
  OTHER
}


enum LeadSource {
  WEBSITE_SDK
  WHATSAPP
  TELEPHONY
  MANUAL
  API_IMPORT
  FACEBOOK_ADS
  DYNAMIC_FORM
}

enum DocumentType {
  PASSPORT
  IELTS
  MARKSHEET_10TH
  MARKSHEET_12TH
  DEGREE
  SOP
  LOR
  OFFER_LETTER
  VISA_DOCUMENT
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FollowupStatus {
  SCHEDULED
  COMPLETED
  MISSED
  CANCELLED
}

enum ApplicationStatus {
  SHORTLISTED
  APPLICATION_STARTED
  APPLICATION_SUBMITTED
  UNDER_REVIEW
  DECISION_RECEIVED
}

enum OfferStatus {
  NONE
  CONDITIONAL_OFFER
  UNCONDITIONAL_OFFER
  OFFER_ACCEPTED
  OFFER_REJECTED
}

enum VisaStatus {
  NOT_STARTED
  VISA_APPLIED
  VISA_BIOMETRICS
  VISA_APPROVED
  VISA_REJECTED
}

model Tenant {
  id           String     @id @default(uuid())
  name         String
  domain       String     @unique
  customDomain String?    @unique
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  users        User[]
  branches     Branch[]
  auditLogs    AuditLog[]
  leads        Lead[]
  visitors     Visitor[]
  emailSetting EmailSetting?
  portalSetting PortalSetting?
  whatsappInstances WhatsappInstance[]
  emailTemplates    EmailTemplate[]
  whatsappTemplates WhatsappTemplate[]
  smsTemplates      SmsTemplate[]
  automationRules   AutomationRule[]
  communicationLogs CommunicationLog[]
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  code      String   @unique
  city      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  leads     Lead[]

  @@index([tenantId])
}

model User {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole   @default(COUNSELLOR)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  auditLogs    AuditLog[]
  assignedLeads Lead[]    @relation("LeadAssignee")
  notes        Note[]
  activities   Activity[]
  followups    Followup[] @relation("FollowupAssignee")
  createdFollowups Followup[] @relation("FollowupCreator")
  approvedDocs LeadDocument[] @relation("DocApprover")
  notifications Notification[]
  sessions     UserSession[]

  fullName     String     @default("")
  password     String     @default("")
  phone        String     @default("")
  designation  String?
}


model Lead {
  id             String      @id @default(uuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId       String?
  branch         Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  firstName      String?
  lastName       String?
  email          String?
  normalizedEmail String?
  phone          String?
  normalizedPhone String?
  address        String?
  status         LeadStatus  @default(NEW_LEAD)
  source         LeadSource  @default(MANUAL)
  assigneeId     String?
  assignee       User?       @relation("LeadAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  visitorId      String?
  visitor        Visitor?    @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  submissionCount Int            @default(1)
  leadCategory   LeadCategory @default(STUDY_ABROAD)
  preferredCountry String?
  preferredCourse  String?
  planningTimeline String?
  intendedIntake   String?
  englishLevel     String?
  targetScore      String?
  purpose          String?
  courseInterest   String?
  readinessScore Float?
  leadNumber     String?     @unique
  studentPortalId String?     @unique
  studentOtpCode  String?
  studentOtpExpiresAt DateTime?
  studentOtpAttempts Int     @default(0)
  studentMagicToken String?   @unique
  studentMagicExpiresAt DateTime?
  emergencyContact String?
  photo            String?

  submissions    LeadSubmission[]
  studentProfile StudentProfile?
  documents      LeadDocument[]
  followups      Followup[]
  activities     Activity[]
  notes          Note[]
  applications   Application[]
  communicationQueues CommunicationQueue[]
  communicationLogs   CommunicationLog[]
  brochureAssignments BrochureAssignment[]
  engagementScore     Int                 @default(0)
  engagementLabel     String              @default("Cold")
  studentSessions      StudentSession[]
  studentNotifications StudentNotification[]
  whatsappMessages     WhatsappMessage[]


  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@index([normalizedEmail])
  @@index([normalizedPhone])
}

model StudentProfile {
  id                   String   @id @default(uuid())
  leadId               String   @unique
  lead                 Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  targetCountry        String?
  targetCourse         String?
  intake               String?
  ieltsStatus          String?
  passportStatus       String?
  educationLevel       String?
  percentageGpa        String?
  budget               String?
  currentQualification String?
  updatedAt            DateTime @updatedAt
}

model Note {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

enum DocumentStatus {
  PENDING
  UPLOADED
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

model LeadDocument {
  id               String         @id @default(uuid())
  leadId           String
  lead             Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  documentType     String
  version          Int            @default(1)
  isCurrent        Boolean        @default(true)
  isRequired       Boolean        @default(true)
  status           DocumentStatus @default(PENDING)
  originalFileName String?
  storedFileName   String?
  filePath         String?
  fileSize         Int?
  mimeType         String?
  uploadedAt       DateTime?
  verifiedAt       DateTime?
  rejectedAt       DateTime?
  verificationNote String?
  expiryDate       DateTime?
  approvedById     String?
  approvedBy       User?          @relation("DocApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([leadId])
  @@index([status])
}

model Followup {
  id             String         @id @default(uuid())
  leadId         String
  lead             Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedUserId String
  assignedUser   User           @relation("FollowupAssignee", fields: [assignedUserId], references: [id], onDelete: Cascade)
  createdById    String?
  createdBy      User?          @relation("FollowupCreator", fields: [createdById], references: [id], onDelete: SetNull)
  followupDate   DateTime
  status         FollowupStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([leadId])
  @@index([assignedUserId])
  @@index([createdById])
  @@index([followupDate])
  @@index([status])
}

model Activity {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  type        String
  description String
  meta        Json?
  createdAt   DateTime @default(now())

  @@index([leadId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String
  targetEntity String
  targetId     String
  beforeState  Json?
  afterState   Json?
  ipAddress    String?
  timestamp    DateTime @default(now())

  @@index([tenantId])
  @@index([targetEntity, targetId])
  @@index([timestamp])
}

model Visitor {
  id        String           @id @default(uuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  leads     Lead[]
  sessions  VisitorSession[]

  @@index([tenantId])
}

model VisitorSession {
  id          String         @id @default(uuid())
  visitorId   String
  visitor     Visitor        @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  sessionId   String         @unique
  referrer    String?
  landingPage String?
  deviceType  String?
  browser     String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  createdAt   DateTime       @default(now())
  events      VisitorEvent[]
  sources     TrackingSource[]

  @@index([visitorId])
  @@index([sessionId])
}

model VisitorEvent {
  id        String         @id @default(uuid())
  sessionId String
  session   VisitorSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  type      String
  meta      Json?
  createdAt DateTime       @default(now())

  @@index([sessionId])
}

model TrackingSource {
  id          String         @id @default(uuid())
  sessionId   String
  session     VisitorSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  source      String
  landingPage String
  referrer    String?
  createdAt   DateTime       @default(now())

  @@index([sessionId])
}

model LeadSubmission {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  country     String?
  course      String?
  intake      String?
  source      String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  referrer    String?
  landingPage String?
  createdAt   DateTime @default(now())

  preferredCountry String?
  preferredCourse  String?
  intendedIntake   String?
  planningTimeline String?
  englishLevel     String?
  targetScore      String?
  purpose          String?
  courseInterest   String?

  @@index([leadId])
}

model Application {
  id                String            @id @default(uuid())
  leadId            String
  lead              Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  universityName    String
  country           String
  courseName        String
  intake            String
  applicationStatus ApplicationStatus @default(SHORTLISTED)
  offerStatus       OfferStatus       @default(NONE)
  visaStatus        VisaStatus        @default(NOT_STARTED)
  applicationDate   DateTime?
  offerDate         DateTime?
  visaDate          DateTime?
  tuitionFee        Float?
  scholarshipAmount Float?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([leadId])
}

enum CommunicationChannel {
  EMAIL
  WHATSAPP
}

enum QueueStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model CommunicationQueue {
  id          String   @id @default(cuid())
  leadId      String
  channel     CommunicationChannel
  eventType   String
  payload     Json
  status      QueueStatus @default(PENDING)
  createdAt   DateTime @default(now())
  processedAt DateTime?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}



model EmailSetting {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  host        String
  port        Int
  username    String
  password    String
  senderName  String
  senderEmail String
  encryption  String   @default("TLS")
  enabled         Boolean  @default(true)
  emailEnabled    Boolean  @default(true)
  whatsappEnabled Boolean  @default(false)
  studentPortalLoginEnabled Boolean @default(true)
  studentMagicLinkEnabled   Boolean @default(true)
  studentEmailOtpEnabled     Boolean @default(true)
  studentSmsOtpEnabled       Boolean @default(false)
  studentWhatsappOtpEnabled  Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Brochure {
  id          String               @id @default(uuid())
  title       String
  category    LeadCategory
  filePath    String
  totalPages  Int
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  assignments BrochureAssignment[]
}

model BrochureAssignment {
  id         String            @id @default(uuid())
  leadId     String
  lead       Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  brochureId String
  brochure   Brochure          @relation(fields: [brochureId], references: [id], onDelete: Cascade)
  token      String            @unique
  assignedAt DateTime          @default(now())
  assignedBy String?
  tracking   BrochureTracking?
}

model BrochureTracking {
  id                   String             @id @default(uuid())
  brochureAssignmentId String             @unique
  assignment           BrochureAssignment @relation(fields: [brochureAssignmentId], references: [id], onDelete: Cascade)
  opened               Boolean            @default(false)
  readingTime          Int                @default(0) // in seconds
  pageViews            Int                @default(0)
  completionPercentage Float              @default(0.0) // 0 to 100
  lastPageViewed       Int                @default(0)
  downloadCount        Int                @default(0)
  viewedPages          String             @default("") // comma-separated unique page numbers (e.g. "1,2")
  engagementScore      Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model StudentSession {
  id           String   @id @default(uuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  token        String   @unique
  browser      String?
  os           String?
  device       String?
  ipAddress    String?
  country      String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActivity DateTime @default(now())

  @@index([leadId])
}

model StudentNotification {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([leadId])
}

model PortalSetting {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  portalName      String   @default("Student Portal")
  logo            String?
  primaryColor    String   @default("#3B82F6")
  secondaryColor  String   @default("#1D4ED8")
  supportEmail    String?
  supportPhone    String?
  privacyPolicy   String?  @db.Text
  termsConditions String?  @db.Text
  footerText      String?
  socialLinks     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WhatsappInstance {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instanceName     String
  phoneNumber      String?
  displayName      String?
  profilePicture   String?
  status           String   @default("DISCONNECTED") // CONNECTED, DISCONNECTED, CONNECTING, QR_PENDING
  connectedAt      DateTime?
  lastSeen         DateTime?
  sessionEncrypted String?  @db.Text // Encrypted authentication state JSON
  sessionVersion   Int      @default(1)
  lastSync         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  messages         WhatsappMessage[]

  @@index([tenantId])
}

model WhatsappMessage {
  id           String    @id @default(uuid())
  leadId       String?
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  instanceId   String
  instance     WhatsappInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  direction    String    // INBOUND or OUTBOUND
  messageType  String    // TEXT, IMAGE, PDF, DOCUMENT, etc.
  messageId    String    @unique
  body         String    @db.Text
  mediaUrl     String?
  status       String    @default("PENDING") // PENDING, SENT, DELIVERED, READ, FAILED
  deliveredAt  DateTime?
  readAt       DateTime?
  failedReason String?
  createdAt    DateTime  @default(now())

  @@index([leadId])
  @@index([instanceId])
}

model EmailTemplate {
  id          String               @id @default(uuid())
  tenantId    String
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  subject     String
  body        String               @db.Text
  category    String               @default("Custom") // Lead, Admissions, Visa, Documents, Payment, Portal, Marketing, Follow-up, Custom
  isActive    Boolean              @default(true)
  version     Int                  @default(1)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  
  versions    EmailTemplateVersion[]
  automations AutomationRule[]

  @@index([tenantId])
}

model EmailTemplateVersion {
  id          String        @id @default(uuid())
  templateId  String
  template    EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version     Int
  subject     String
  body        String        @db.Text
  createdAt   DateTime      @default(now())

  @@index([templateId])
}

model WhatsappTemplate {
  id          String                  @id @default(uuid())
  tenantId    String
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  category    String                  @default("Custom")
  body        String                  @db.Text
  message     String?                 @db.Text
  isActive    Boolean                 @default(true)
  version     Int                     @default(1)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  versions    WhatsappTemplateVersion[]
  automations AutomationRule[]

  @@index([tenantId])
}

model WhatsappTemplateVersion {
  id          String           @id @default(uuid())
  templateId  String
  template    WhatsappTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version     Int
  body        String           @db.Text
  message     String?          @db.Text
  createdAt   DateTime         @default(now())

  @@index([templateId])
}

model SmsTemplate {
  id          String               @id @default(uuid())
  tenantId    String
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  category    String               @default("Custom")
  body        String               @db.Text
  isActive    Boolean              @default(true)
  version     Int                  @default(1)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  versions    SmsTemplateVersion[]
  automations AutomationRule[]

  @@index([tenantId])
}

model SmsTemplateVersion {
  id          String      @id @default(uuid())
  templateId  String
  template    SmsTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version     Int
  body        String      @db.Text
  createdAt   DateTime    @default(now())

  @@index([templateId])
}

model AutomationRule {
  id                 String            @id @default(uuid())
  tenantId           String
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  trigger            String            // e.g. LEAD_CREATED, DOCUMENT_PENDING, FOLLOWUP_REMINDER, etc.
  channel            String            // EMAIL, WHATSAPP, SMS
  emailTemplateId    String?
  emailTemplate      EmailTemplate?    @relation(fields: [emailTemplateId], references: [id], onDelete: SetNull)
  whatsappTemplateId String?
  whatsappTemplate   WhatsappTemplate? @relation(fields: [whatsappTemplateId], references: [id], onDelete: SetNull)
  smsTemplateId      String?
  smsTemplate        SmsTemplate?      @relation(fields: [smsTemplateId], references: [id], onDelete: SetNull)
  delayType          String            @default("IMMEDIATE") // IMMEDIATE, DELAYED
  delayDuration      String?           // e.g. "5m", "1h", "1d"
  conditions         Json?             // Rule Builder JSON: e.g. { "country": "Germany" }
  enabled            Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  logs               CommunicationLog[]

  @@index([tenantId])
}

model CommunicationLog {
  id           String          @id @default(uuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId       String
  lead         Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  automationId String?
  automation   AutomationRule? @relation(fields: [automationId], references: [id], onDelete: SetNull)
  channel      String          // EMAIL, WHATSAPP, SMS
  eventType    String          // Trigger / event name e.g., LEAD_CREATED
  status       String          // SENT, FAILED, PENDING
  recipient    String
  message      String          @db.Text
  failedReason String?         @db.Text
  createdAt    DateTime        @default(now())
  sentAt       DateTime        @default(now())
  openedAt     DateTime?
  clickedAt    DateTime?

  @@index([tenantId])
  @@index([leadId])
}

