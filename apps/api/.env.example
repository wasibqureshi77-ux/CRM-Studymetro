# Study Metro CRM & Analytics Platform - Production Environment Template

# Server Configuration
PORT=4000

# Supabase PostgreSQL Database Links
# DATABASE_URL: Use Supabase Connection Pooler link (transaction mode, port 6543) for application performance.
# Example: postgresql://postgres.xxxx:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: Use Supabase Direct Database Connection link (session mode, port 5432) for running migrations.
# Example: postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Authentication JWT Tokens Secrets
JWT_SECRET="generate-a-long-random-string-for-access-token-encryption"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="generate-a-long-random-string-for-refresh-token-encryption"
JWT_REFRESH_EXPIRATION="7d"
